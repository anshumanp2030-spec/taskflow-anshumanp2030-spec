# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=taskflow
DB_SSLMODE=disable

# ── JWT ─────────────────────────────────────────────────────────────────────
# REQUIRED — generate a strong random secret, e.g.:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret-before-deploying

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
ENV=development

# ── CORS ────────────────────────────────────────────────────────────────────
# Set to your frontend origin in production, e.g. https://app.example.com
CORS_ORIGIN=*
